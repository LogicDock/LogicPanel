# LogicPanel Configuration
APP_NAME=LogicPanel
APP_URL=http://localhost/logicpanel
APP_DEBUG=true
APP_SECRET=your-secret-key-here-change-in-production

# Database Configuration (MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=logicpanel
DB_USERNAME=root
DB_PASSWORD=

# Docker Configuration
DOCKER_HOST=unix
DOCKER_PORT=2375
DOCKER_TLS=false
DOCKER_CERT_PATH=

# NGINX Proxy Network
NGINX_PROXY_NETWORK=nginx-proxy_web

# JWT Settings
JWT_SECRET=your-jwt-secret-change-this
JWT_EXPIRY=86400

# WHMCS Integration
WHMCS_API_KEY=your-whmcs-api-key
WHMCS_API_SECRET=your-whmcs-api-secret

# Backup Settings
BACKUP_PATH=/var/logicpanel/backups
MAX_BACKUPS_PER_SERVICE=5
