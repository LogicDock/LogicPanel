{
    "name": "logicdock/logicpanel",
    "description": "LogicPanel - Docker Container Management Panel",
    "type": "project",
    "require": {
        "php": "^8.1",
        "slim/slim": "^4.15",
        "slim/psr7": "^1.8",
        "php-di/php-di": "^7.1",
        "illuminate/database": "^12.46",
        "vlucas/phpdotenv": "^5.6",
        "firebase/php-jwt": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "LogicPanel\\": "src/"
